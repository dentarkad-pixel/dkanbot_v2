# Required
BOT_TOKEN=1234567890:REPLACE_WITH_BOTFATHER_TOKEN

# Optional: group IDs (defaults are already in code)
GROUP_NEW_ID=-1000000000001
GROUP_DESIGN_ID=-1000000000002
GROUP_READY_ID=-1000000000003
GROUP_SENT_ID=-1000000000004
GROUP_ISSUES_ID=-1000000000005

# Optional: if using forum topics for NEW statuses
FORUM_GROUP_ID=-1000000000001
TOPIC_NEW_ID=1
TOPIC_NEW_SPORT_SETS_ID=2
TOPIC_NEW_EMBROIDERY_ID=3
TOPIC_NEW_PRINTING_ID=4
TOPIC_NEW_URGENT_ID=5

# Optional: route these statuses to topics in same forum group
TOPIC_DESIGN_ID=6
TOPIC_READY_ID=7
TOPIC_SENT_ID=8
TOPIC_ISSUES_ID=9

# Optional fallback aliases supported by code
TOPIC_SPORT_ID=2
TOPIC_EMBROIDERY_ID=3
TOPIC_PRINTING_ID=4
TOPIC_URGENT_ID=5

# Recommended for Railway logs
PYTHONUNBUFFERED=1

# Persistent data folder (Railway volume mount, e.g. /data)
DATA_DIR=.

# Optional: path to Excel template (leave empty on Railway)
EXCEL_TEMPLATE_PATH=
